# ================================================================
# ケンミツ / 見積書メーカー — 環境変数のサンプル
# ----------------------------------------------------------------
# このファイルは実際の秘密値を含みません。本番の Vercel では
# Settings → Environment Variables から各値を設定してください。
#
# ローカル開発時は .env.local にコピーして実値を入れる。
# ================================================================


# ================== Supabase（認証・DB） =================
# 必須。未設定時はログイン・保存系のUIが「準備中」表示にフォールバック。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 管理ダッシュボード・Webhook・Cron 等のサーバー側処理に使用
SUPABASE_SERVICE_ROLE_KEY=


# ================== Stripe（決済） =====================
# 本番切替時に必須。手順は docs/setup-instructions/06-stripe-production.md
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Dashboard で作成した商品の Price ID
STRIPE_PRICE_SOLO_MONTHLY=
STRIPE_PRICE_SOLO_YEARLY=
# Team は準備中の間は未設定で可
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=


# ================== Resend（メール送信） =================
# 確認メール・チェックリスト配布・解約通知・週次レポートで使用
# 手順: docs/setup-instructions/02-resend-setup.md
RESEND_API_KEY=
# 認証済みドメインの送信元アドレス
RESEND_FROM_EMAIL=noreply@mitsumori-maker.com


# ================== Analytics / 広告タグ ================
# Google Ads（検索広告・ディスプレイ）
# 手順: docs/setup-instructions/04-google-ads.md
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Google Ads コンバージョン変換ラベル
# Google Ads 管理画面で各コンバージョンを作成して発行
NEXT_PUBLIC_GADS_CONV_TOOL_START=
NEXT_PUBLIC_GADS_CONV_PDF=
NEXT_PUBLIC_GADS_CONV_SIGNUP=
NEXT_PUBLIC_GADS_CONV_SUB_SOLO=
NEXT_PUBLIC_GADS_CONV_SUB_TEAM=

# Meta Pixel（Facebook / Instagram 広告）
# 手順: docs/setup-instructions/03-meta-pixel.md
NEXT_PUBLIC_META_PIXEL_ID=


# ================== AI 積算（Anthropic） =================
# AI Takeoff 機能で使用。未設定なら機能は 503 を返す（「準備中」表示）
ANTHROPIC_API_KEY=


# ================== 管理・運用 =====================
# 管理ダッシュボード (/construction/admin) へのアクセス許可メールアドレス
# カンマ区切りで複数指定可
ADMIN_EMAILS=you@example.com

# 管理ダッシュボードのベーシック認証（Stripe セキュリティチェックリスト #1 対応）
# middleware.ts で /construction/admin 配下へのアクセス時に要求
# 両方未設定なら Basic 認証はスキップ（開発環境向け）
# 本番では必ず両方設定すること
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASS=

# Vercel Cron からの呼び出し認証（ドリップメール用）
CRON_SECRET=

# GitHub Actions トリガー用（任意）
GITHUB_TOKEN=

# GA4 Data API（/api/admin/analytics で使用）
# Google Cloud のサービスアカウント JSON キーを base64 エンコードして格納
# 生成方法: base64 -i service-account-key.json | pbcopy  (macOS)
# GA4 側でサービスアカウントのメールに「閲覧者」権限を付与しておくこと
GA4_SA_KEY_B64=
# GA4 プロパティ ID（9 桁の数字。G-XXX は測定 ID なので別物）
GA4_PROPERTY_ID=
